{
    "layer": "silver",
    "project": "games_analytics",
    "subject": "IGDB",
    "table": "companies",
    "datalake_path": "s3a://datalake",
    "step_raw_to_bronze": {
        "source": {
            "format": "json",
            "options": {
              "inferSchema": "true",
              "multiLine": "true"
            }
        },
        "target": {
            "options": {
                "primary_key": ["id"],
                "sequence_by": ["_bronze_created_at"],
                "mode": "append"
            }
        }
    },
    "step_bronze_to_silver": {
        "source": {
            "format": "delta"
        },
        "target": {
            "options": {
                "primary_key": ["id"],
                "sequence_by": ["_silver_created_at"],
                "mode": "append"
            },
            "sql_transformations": {
                "10-add-silver-columns": [ "current_timestamp() _silver_created_at" ],
                "20-common-table-converts": ["from_unixtime(created_at) as created_at_ts", "from_unixtime(updated_at) as updated_at_ts"],
                "30-companies-specific-transforms": ["from_unixtime(start_date) as start_date_ts", "from_unixtime(change_date) as change_date_ts"]
            }
        }
    }
}